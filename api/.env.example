# API 环境变量配置示例
# 复制此文件为 .dev.vars 并填入实际值

# JWT 密钥 - 用于生成和验证 JWT Token
# 生产环境请使用：wrangler secret put JWT_SECRET
JWT_SECRET=your-local-jwt-secret-key

# 通义千问 API 密钥
# 生产环境请使用：wrangler secret put DASHSCOPE_API_KEY
DASHSCOPE_API_KEY=your-dashscope-api-key

# Cloudflare API Token（可选，用于某些自动化操作）
# 生产环境请使用：wrangler secret put CLOUDFLARE_API_TOKEN
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
